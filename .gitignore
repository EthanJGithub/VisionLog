# Python
.venv/
__pycache__/
*.pyc
.cache/
*.log

# Local data / secrets
data/*.db
data/*.db-*
.env

# Node / Vite
frontend/node_modules/
frontend/dist/

# Test artifacts
tests/fixtures/*.mp4
.pytest_cache/

# Stray model weights / caches downloaded by ultralytics at export/open-vocab time
*.pt
mobileclip*.ts
*.engine

# Keep the exported ONNX models + sample image (committed for deterministic/demoable builds)
!models/*.onnx
!frontend/public/models/*.onnx
!tests/fixtures/bus.jpg

# yolo26x is 223MB — exceeds GitHub's 100MB file limit. Served on deploy (HF Space),
# not committed. The UI shows it as unavailable when the file isn't served.
models/yolo26x.onnx
frontend/public/models/yolo26x.onnx
# m is committed only in the client dir (public/models); the server uses ultralytics for m.
models/yolo26m.onnx

# Ultralytics eval scratch
runs/

# Lighthouse reports
lh*.json

# Session handoff — kept local, never committed (per user)
SESSION_STATE.md
