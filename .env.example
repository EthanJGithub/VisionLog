# VisionLog configuration. Copy to .env for local dev; set as secrets in production.

# --- Database -----------------------------------------------------------------------
# Local default (SQLite) is used if unset. In production set a Neon Postgres URL:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
# DATABASE_URL=

# --- Model / inference --------------------------------------------------------------
# VISIONLOG_MODEL=models/yolo26n.onnx
# VISIONLOG_MODEL_VERSION=yolo26n-onnx
# VISIONLOG_CONF_THRESHOLD=0.35
# VISIONLOG_INPUT_SIZE=640

# --- Free-tier guardrails -----------------------------------------------------------
# VISIONLOG_SAMPLE_FPS=5
# VISIONLOG_MAX_UPLOAD_MB=50
# VISIONLOG_MAX_DURATION_SECONDS=60

# --- App ----------------------------------------------------------------------------
# VISIONLOG_CORS_ORIGINS=*
