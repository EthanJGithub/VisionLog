# Keep the Vercel upload lean — exclude local scratch, caches, and heavy local-only files.
.venv
.cache
*.log
**/__pycache__
# Exclude ONLY the repo-root server-side ONNX scratch dir — anchored with a leading slash so
# it does NOT also strip frontend/public/models/ (the client models the static build serves).
/models/
data/*.db
data/*.db-*
tests/fixtures/*.mp4
frontend/node_modules
.git
.pytest_cache
